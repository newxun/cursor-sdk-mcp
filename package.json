{
  "name": "cursor-sdk-mcp",
  "version": "0.1.0",
  "description": "An MCP server that lets MCP clients (e.g. Claude Code) invoke the Cursor SDK to use Cursor Agent capabilities.",
  "type": "module",
  "bin": {
    "cursor-sdk-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "demo": "tsx examples/demo-client.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cursor",
    "cursor-sdk",
    "cursor-agent",
    "claude-code"
  ],
  "license": "MIT",
  "dependencies": {
    "@connectrpc/connect-node": "^1.7.0",
    "@cursor/sdk": "^1.0.19",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.13.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  }
}
