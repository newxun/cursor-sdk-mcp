# Cursor API key used by the Cursor SDK.
# Create one at: Cursor Dashboard -> API Keys (user key) or Team settings (service account key).
CURSOR_API_KEY=your-cursor-api-key

# Optional: default model id used when a tool call does not specify one.
# Discover valid ids with the `cursor_list_models` tool. Defaults to "auto".
CURSOR_MCP_DEFAULT_MODEL=auto
